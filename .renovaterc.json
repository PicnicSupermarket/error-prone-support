{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "commitMessagePrefix": "",
  "extends": [
    "helpers:pinGitHubActionDigests"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^integration-tests/.*(-init\\.patch|\\.sh)$/"
      ],
      "matchStrings": [
        "\\b(?<packageName>[a-z0-9_.-]+?:[a-z0-9_.-]+?):(?<currentValue>[^:]+?):[a-zA-Z0-9_-]+\\b",
        "<version>(?<currentValue>.*?)<!-- Renovate: (?<packageName>.*?) --></version>"
      ],
      "datasourceTemplate": "maven"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.actrc$/"
      ],
      "matchStrings": [
        "catthehacker/ubuntu:(?<currentValue>act-24\\.04-\\d+)@(?<currentDigest>sha256:[a-f0-9]+)"
      ],
      "datasourceTemplate": "docker",
      "packageNameTemplate": "catthehacker/ubuntu",
      "versioningTemplate": "regex:^act-24\\.04-(?<major>\\d{4})(?<minor>\\d{2})(?<patch>\\d{2})$"
    }
  ],
  "packageRules": [
    {
      "matchPackageNames": [
        "/^org\\.springframework:spring-framework-bom$/",
        "/^org\\.springframework\\.boot:spring-boot[a-z-]*$/"
      ],
      "separateMinorPatch": true
    },
    {
      "matchPackageNames": [
        "catthehacker/ubuntu"
      ],
      "schedule": "every 4 weeks on Monday"
    },
    {
      "matchPackageNames": [
        "dawidd6/action-download-artifact",
        "github/codeql-action",
        "ruby/setup-ruby"
      ],
      "schedule": "every 4 weeks on Monday"
    }
  ],
  "reviewers": [
    "rickie",
    "Stephan202"
  ]
}
